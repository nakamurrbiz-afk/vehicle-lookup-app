{
  "expo": {
    "name": "Ban-go",
    "slug": "vehicle-lookup-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6FFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nakamurrbizafk.vehiclelookupapp",
      "buildNumber": "2",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Ban-go uses your location to automatically detect your country and postcode, so nearby used-car listings appear without manual input. For example, if you are in the United Kingdom, the app sets the country to GB and pre-fills your postcode (e.g. SW1A 2AA) so search results are sorted by proximity to you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A6FFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Ban-go uses your camera to scan license plates automatically."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c0a379b5-7ae7-4422-88f4-419e197b5c29"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c0a379b5-7ae7-4422-88f4-419e197b5c29"
    }
  }
}
