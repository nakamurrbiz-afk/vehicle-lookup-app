{
  "expo": {
    "name": "Ban-go",
    "slug": "vehicle-lookup-app",
    "version": "1.0.2", // ← 1.0.1 から 1.0.2 に上げる
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A6FFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nakamurrbizafk.vehiclelookupapp",
      "buildNumber": "2", // ← ここを追加（前回のビルドが1なら2にする）
      "icon": "./assets/icon.png", // ← ここを明示的に追加（アイコン反映を確実にするため）
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Your location is used to display nearby parking lots and vehicles on the map for seamless lookups. For example, it helps automatically prioritize the closest registered vehicles."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A6FFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c0a379b5-7ae7-4422-88f4-419e197b5c29"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c0a379b5-7ae7-4422-88f4-419e197b5c29"
    }
  }
}